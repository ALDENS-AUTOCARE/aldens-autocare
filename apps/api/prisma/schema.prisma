generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(uuid())
  fullName      String
  email         String      @unique
  phone         String?
  passwordHash  String
  role          Role        @default(CUSTOMER)
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bookings      Booking[]
  payments      Payment[]
  subscriptions Subscription[]
}

model Service {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  description     String
  basePrice       Decimal  @db.Decimal(10, 2)
  durationMinutes Int
  isPremium       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings        Booking[]
}

model Booking {
  id                 String             @id @default(uuid())
  customerId         String
  serviceId          String
  subscriptionId     String?
  customerPlanCode   String?
  bookingFundingType BookingFundingType @default(ONE_TIME)
  vehicleType        String
  vehicleMake        String?
  vehicleModel       String?
  vehicleColor       String?
  vehiclePlate       String?
  serviceAddress     String
  locationArea       String?
  scheduledDate      DateTime
  notes              String?
  status             BookingStatus      @default(PENDING)
  paymentStatus      PaymentStatus      @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  customer           User               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service            Service            @relation(fields: [serviceId], references: [id])
  subscription       Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payments           Payment[]

  @@index([customerId])
  @@index([serviceId])
  @@index([subscriptionId])
  @@index([scheduledDate])
  @@index([status])
  @@index([paymentStatus])
  @@index([bookingFundingType])
}

model Payment {
  id                String          @id @default(uuid())
  userId            String
  bookingId         String?
  subscriptionId    String?
  provider          PaymentProvider
  providerReference String?         @unique
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("GHS")
  status            PaymentStatus   @default(PENDING)
  paymentType       PaymentType
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking           Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  subscription      Subscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookingId])
  @@index([subscriptionId])
  @@index([provider])
  @@index([status])
}

model Plan {
  id                    String   @id @default(uuid())
  code                  String   @unique
  name                  String
  description           String
  monthlyPrice          Decimal  @db.Decimal(10, 2)
  yearlyPrice           Decimal? @db.Decimal(10, 2)
  includedBookings      Int      @default(0)
  allowsPremiumServices Boolean  @default(false)
  allowsPriorityBooking Boolean  @default(false)
  allowsFleetDashboard  Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subscriptions         Subscription[]

  @@index([code])
  @@index([isActive])
}

model Subscription {
  id                String             @id @default(uuid())
  userId            String?
  companyId         String?
  planId            String
  provider          PaymentProvider
  providerReference String?
  status            SubscriptionStatus @default(PENDING)
  billingCycle      BillingCycle
  startDate         DateTime
  renewalDate       DateTime
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              Plan               @relation(fields: [planId], references: [id])
  bookings          Booking[]
  payments          Payment[]
  usageRecords      SubscriptionUsage[]

  @@index([userId])
  @@index([companyId])
  @@index([planId])
  @@index([status])
  @@index([renewalDate])
}

model SubscriptionUsage {
  id             String           @id @default(uuid())
  subscriptionId String
  bookingId      String?
  usageType      UsageType
  periodKey      String
  usedCount      Int              @default(1)
  createdAt      DateTime         @default(now())

  subscription   Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([periodKey])
  @@index([usageType])
  @@unique([subscriptionId, periodKey, usageType])
}

model Company {
  id          String   @id @default(uuid())
  companyName String
  contactName String?
  email       String?  @unique
  phone       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum BookingStatus {
  PENDING
  AWAITING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  MTN_MOMO
}

enum PaymentType {
  BOOKING_DEPOSIT
  FULL_BOOKING_PAYMENT
  SUBSCRIPTION_INITIAL
  SUBSCRIPTION_RENEWAL
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum UsageType {
  INCLUDED_BOOKING
  PREMIUM_ACCESS
  PRIORITY_BOOKING
}

enum BookingFundingType {
  ONE_TIME
  SUBSCRIPTION_INCLUDED
}
